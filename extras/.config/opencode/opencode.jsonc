{
  "$schema": "https://opencode.ai/config.json",
  // "plugin": [
  //   "oh-my-openagent@latest"
  // ],
  "lsp": {
    "oxlint": {
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ],
      "command": [
        "oxlint",
        "--lsp"
      ]
    }
  },
  "provider": {
    "llama-swap": {
      "models": {
        "Qwen3.6-35B-A3B": {
          "name": "Qwen3.6-35B-A3B",
          "reasoning": true,
          "tool_call": true
        },
        "gemma-4-26B-A4B-it": {
          "name": "gemma-4-26B-A4B-it",
          "reasoning": true,
          "tool_call": true
        }
      },
      "name": "llama-swap",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "builder-mcp": {
      "type": "local",
      "command": [
        "builder.io",
        "mcp"
      ],
      "enabled": false
    },
    "codebase-memory-mcp": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "enabled": true
    },
    "playwright-mcp": {
      "type": "local",
      "command": [
        "playwright-mcp"
      ],
      "enabled": true
    }
  }
}
